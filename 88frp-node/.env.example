# Web 服务监听地址
# 0.0.0.0 表示允许局域网访问，127.0.0.1 表示仅本机访问
HOST=0.0.0.0

# Web 服务端口
PORT=8801

# 数据目录，建议填写绝对路径
# Windows 示例：D:\88frp-node\data
# Linux 示例：/opt/88frp-node/data
DATA_DIR=/opt/88frp/data

# frpc 可执行文件路径，可留空
# 单文件版通常不需要填写，程序会自动使用内嵌并释放出来的 frpc
# 只有你想手动覆盖默认 frpc 路径时才需要填写绝对路径
# Windows 示例：D:\88frp-node\bin\amd64\88frpc.exe
# Linux amd64 示例：/opt/88frp-node/bin/amd64/88frpc
# Linux arm64 示例：/opt/88frp-node/bin/arm64/88frpc
FRPC_BINARY_PATH=

# 自动同步间隔，单位毫秒
AUTO_SYNC_INTERVAL_MS=60000

# 服务启动时是否自动恢复实例
# 1 表示开启，0 表示关闭
INSTANCE_AUTO_START_ON_BOOT=1

# 应用根目录，建议填写绝对路径
# 单文件版会基于这个目录生成 data 和 runtime 子目录
# Windows 示例：D:\88frp-node
# Linux 示例：/opt/88frp-node
APP_BASE_DIR=/opt/88frp

# 运行时资源释放目录，建议填写绝对路径
# 单文件版会把内嵌的 public 和 frpc 释放到这里
# Windows 示例：D:\88frp-node\runtime
# Linux 示例：/opt/88frp-node/runtime
APP_RUNTIME_DIR=/opt/88frp/runtime

# agent 服务监听地址
AGENT_HOST=127.0.0.1

# agent 服务端口
AGENT_PORT=19688
