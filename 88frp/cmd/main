#!/bin/bash

NODE_BIN_DIR="/var/apps/nodejs_v22/target/bin"
export PATH="${NODE_BIN_DIR}:$PATH"

LOG_FILE="${TRIM_PKGVAR}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"
APP_ENTRY="${TRIM_APPDEST}/server/index.js"
CONFIG_FILE="${TRIM_PKGETC}/server.env"
DEFAULT_PORT="${TRIM_SERVICE_PORT:-8801}"
SERVICE_HOST="127.0.0.1"

read_config_vars() {
    if [ -f "${CONFIG_FILE}" ]; then
        # shellcheck disable=SC1090
        . "${CONFIG_FILE}"
    fi

    echo "${web_port:-$DEFAULT_PORT}|${remote_url}"
}

VARS="$(read_config_vars)"
SERVICE_PORT="${VARS%|*}"
REMOTE_URL="${VARS#*|}"
CMD="PORT=${SERVICE_PORT} HOST=${SERVICE_HOST} web_port=${SERVICE_PORT} remote_url=\"${REMOTE_URL}\" FNOS_APPDEST=${TRIM_APPDEST} FNOS_PKGVAR=${TRIM_PKGVAR} FNOS_PKGETC=${TRIM_PKGETC} node ${APP_ENTRY}"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "${LOG_FILE}"
}

report_error() {
    local message="$1"
    if [ -n "${TRIM_TEMP_LOGFILE}" ]; then
        echo "${message}" > "${TRIM_TEMP_LOGFILE}"
    fi
    log_msg "${message}"
}

check_process() {
    local pid=$1
    if kill -0 "${pid}" 2>/dev/null; then
        return 0
    fi

    return 1
}

validate_port() {
    case "$1" in
        ''|*[!0-9]*)
            return 1
            ;;
    esac

    if [ "$1" -lt 1 ] || [ "$1" -gt 65535 ]; then
        return 1
    fi

    return 0
}

port_in_use() {
    local port="$1"

    if command -v ss >/dev/null 2>&1; then
        ss -ltn 2>/dev/null | awk '{print $4}' | grep -Eq "[:.]${port}$"
        return $?
    fi

    if command -v netstat >/dev/null 2>&1; then
        netstat -ltn 2>/dev/null | awk '{print $4}' | grep -Eq "[:.]${port}$"
        return $?
    fi

    return 1
}

status() {
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if check_process "${pid}"; then
            return 0
        fi

        rm -f "${PID_FILE}"
    fi

    return 1
}

start_process() {
    if status; then
        log_msg "Node manager already running."
        return 0
    fi

    if ! command -v node >/dev/null 2>&1; then
        report_error "未找到 nodejs_v22 运行时，请确认依赖应用已安装。"
        return 1
    fi

    if [ ! -f "${APP_ENTRY}" ]; then
        report_error "未找到 88FRP 管理服务入口文件，应用启动失败。"
        return 1
    fi

    VARS="$(read_config_vars)"
    SERVICE_PORT="${VARS%|*}"
    REMOTE_URL="${VARS#*|}"

    if ! validate_port "${SERVICE_PORT}"; then
        report_error "88FRP 配置的端口无效，请检查 web_port 配置。"
        return 1
    fi

    if port_in_use "${SERVICE_PORT}"; then
        report_error "端口 ${SERVICE_PORT} 已被占用，请修改 88FRP 的 web_port 配置后重试。"
        return 1
    fi

    mkdir -p "${TRIM_PKGVAR}"
    touch "${LOG_FILE}"

    CMD="PORT=${SERVICE_PORT} HOST=${SERVICE_HOST} web_port=${SERVICE_PORT} remote_url=\"${REMOTE_URL}\" FNOS_APPDEST=${TRIM_APPDEST} FNOS_PKGVAR=${TRIM_PKGVAR} FNOS_PKGETC=${TRIM_PKGETC} node ${APP_ENTRY}"
    log_msg "Starting 88FRP manager on port ${SERVICE_PORT} ..."
    bash -c "${CMD}" >> "${LOG_FILE}" 2>&1 &
    printf "%s" "$!" > "${PID_FILE}"
    sleep 1

    if ! status; then
        report_error "88FRP 管理服务启动失败，请查看应用日志。"
        return 1
    fi

    log_msg "88FRP manager started."
    return 0
}

stop_process() {
    log_msg "Stopping 88FRP manager ..."

    if [ -r "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')

        if ! check_process "${pid}"; then
            rm -f "${PID_FILE}"
            return 0
        fi

        kill -TERM "${pid}" >> "${LOG_FILE}" 2>&1

        local count=0
        while check_process "${pid}" && [ $count -lt 10 ]; do
            sleep 1
            count=$((count + 1))
        done

        if check_process "${pid}"; then
            kill -KILL "${pid}" >> "${LOG_FILE}" 2>&1
            sleep 1
        fi

        rm -f "${PID_FILE}"
    fi

    log_msg "88FRP manager stopped."
    return 0
}

case $1 in
start)
    start_process || exit 1
    ;;
stop)
    stop_process || exit 1
    ;;
status)
    if status; then
        exit 0
    else
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac
