#!/bin/bash

### This script is called after the user installs the application.

# 持久化安装向导中定义的配置
if [ -n "$web_port" ] || [ -n "$remote_url" ]; then
    mkdir -p "${TRIM_PKGETC}"
    {
        [ -n "$web_port" ] && echo "web_port=$web_port"
        [ -n "$remote_url" ] && echo "remote_url=\"$remote_url\""
    } > "${TRIM_PKGETC}/server.env"
fi

chmod +x \
    "${TRIM_APPDEST}/ui/index.cgi" \
    "${TRIM_APPDEST}/ui/api.cgi" \
    "${TRIM_APPDEST}/../cmd/main" \
    "${TRIM_APPDEST}/../cmd/config_init" \
    "${TRIM_APPDEST}/../cmd/config_callback" \
    "${TRIM_APPDEST}/../cmd/install_callback" \
    "${TRIM_APPDEST}/../cmd/upgrade_callback" 2>/dev/null || true

exit 0
